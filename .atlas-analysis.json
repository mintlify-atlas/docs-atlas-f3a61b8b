  "keyFeatures": [
    "Offline-first PWA that works without internet connection",
    "Battery inspection form with visual and measurement fields",
    "Custom battery reference management with charge/weight validation ranges",
    "Automatic synchronization to Google Sheets with exponential backoff retry",
    "Background Sync API via Service Worker for connection recovery",
    "IndexedDB local storage for pending records and custom references",
    "Daily history view of inspection records",
    "Installable as a standalone app on mobile and desktop"
  ],
  "publicApiSurface": [
    "BatteryReference interface",
    "BatteryRecord interface",
    "SyncResult interface",
    "getAllReferences()",
    "getReferencesForSelect()",
    "getReferenceById(code)",
    "saveCustomReference(reference)",
    "deleteCustomReference(id)",
    "getCustomReferences()",
    "getReferencesByVoltage(voltage)",
    "sendRecord(record)",
    "sendRecordsWithRetry(records, onProgress?)",
    "startAutoSync()",
    "stopAutoSync()",
    "setCustomReferencesStorage(storage)",
    "getCacheInfo()",
    "getCacheSize()",
    "clearAllCaches()",
    "useOnlineStatus() hook"
  ]
